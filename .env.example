# ---------------------------------------------------------------------------
# Asana Shelf Sync - environment variables
# Copy to .env.local for local dev, and set the same keys in Vercel Project
# Settings -> Environment Variables for production.
# NEVER commit real secrets.
# ---------------------------------------------------------------------------

# Asana Personal Access Token (https://app.asana.com/0/my-apps).
# Needs read/write access to the project's tasks.
ASANA_PAT=

# Asana identifiers (defaults are baked in code but can be overridden).
ASANA_PROJECT_GID=1209435989338394
ASANA_WORKSPACE_GID=1209435871242085
ASANA_SERIAL_CUSTOM_FIELD_GID=1209458789411568
ASANA_SHELF_CUSTOM_FIELD_GID=1215845672985246

# Asana webhook secret.
# Leave EMPTY for the very first deploy. Asana sends it during the handshake;
# capture it from the Vercel runtime logs and paste it here, then redeploy.
ASANA_WEBHOOK_SECRET=

# Google service account credentials (Sheets API, read-only is enough).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Paste the full private key. Newlines may be escaped as \n - the code converts
# them back to real newlines automatically. Wrap the whole value in quotes.
GOOGLE_PRIVATE_KEY=

# The spreadsheet ID (the long id in the sheet URL between /d/ and /edit).
GOOGLE_SHEET_ID=

# Range to read. Column A = serial number, Column B = shelf.
# NOTE: the source tab name currently has a TRAILING SPACE after "estoque".
GOOGLE_SHEET_RANGE=Conferencia de estoque !A:B
